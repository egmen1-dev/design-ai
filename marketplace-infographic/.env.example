NEXTAUTH_URL="https://design-ai.shop"
AUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_SECRET="change-me-to-a-random-secret"
AUTH_TRUST_HOST=true
GITHUB_ID=""
GITHUB_SECRET=""
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:7b"
AI_MOCK_MODE="false"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
WATERMARK_TEXT="design-ai"
ADMIN_EMAILS="admin@example.com"

# ── Render Engine v17 (Pollinations) — рекомендуется для продакшена ──
RENDER_ENGINE_V17=1
PIPELINE_V17=1
POLLINATIONS_API_KEY=""
POLLINATIONS_SKIP_MODELS=gptimage
RENDER_PROVIDER=pollinations

# ── Design Governance v17.1 (авто при RENDER_ENGINE_V17=1) ──
DESIGN_GOVERNANCE_V171=1
GOVERNANCE_CONSTITUTION_THRESHOLD=80
GOVERNANCE_PROFESSIONAL_THRESHOLD=75
GOVERNANCE_PROFESSIONAL_NEAR_MISS=3
GOVERNANCE_ALLOW_GRADIENT_FALLBACK=0

# ── Render Blueprint v18 (фаза 1 — типы, пока без полного handler) ──
# RENDER_BLUEPRINT_V18=1

# ── Legacy v16 (только если RENDER_ENGINE_V17=0) ──
HF_API_KEY=""
HF_SD_MODEL="black-forest-labs/FLUX.1-schnell"

# ── Performance ──
FAST_GENERATION=1
DISABLE_IMGLY=0
