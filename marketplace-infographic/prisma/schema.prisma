generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(cuid())
  name             String?
  email            String?          @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  stripeCustomerId String?          @unique
  credits          Int              @default(0)
  accounts         Account[]
  sessions         Session[]
  subscription     Subscription?
  creditPurchases  CreditPurchase[]
  generatedImages  GeneratedImage[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String   @unique
  stripePriceId        String
  status               String
  plan                 String
  currentPeriodEnd     DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model CreditPurchase {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credits         Int
  priceRub        Int
  stripeSessionId String   @unique
  createdAt       DateTime @default(now())
}

model GeneratedImage {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt        String   @db.Text
  htmlContent   String   @db.Text
  imagePath     String
  generatedJson String?  @db.Text
  backgroundUrl String?
  productCutout String?
  usedFreeQuota Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model BackgroundCache {
  id         String   @id @default(cuid())
  promptHash String   @unique
  imageUrl   String
  createdAt  DateTime @default(now())
}

enum FontCategory {
  sans_serif
  serif
  display
  monospace
}

model LibraryFont {
  id             String          @id @default(uuid())
  name           String
  cssImport      String          @db.Text
  fontFamily     String
  category       FontCategory
  styleTags      String[]
  createdAt      DateTime        @default(now())
  designExamples DesignExample[]
}

model LibraryBadge {
  id             String          @id @default(uuid())
  name           String
  htmlTemplate   String          @db.Text
  svgTemplate    String?         @db.Text
  pngUrl         String?
  styleTags      String[]
  createdAt      DateTime        @default(now())
  designExamples DesignExample[]
}

model ReferenceImage {
  id          String   @id @default(uuid())
  originalUrl String
  notes       String?
  createdAt   DateTime @default(now())
}

model DesignExample {
  id           String        @id @default(uuid())
  prompt       String        @db.Text
  resultJson   String        @db.Text
  imageUrl     String?
  notes        String?
  fontId       String?
  font         LibraryFont?  @relation(fields: [fontId], references: [id], onDelete: SetNull)
  badgeId      String?
  badge        LibraryBadge? @relation(fields: [badgeId], references: [id], onDelete: SetNull)
  appliedStyle String
  tags         String[]
  createdAt    DateTime      @default(now())
}
